# ResQPaws - Email Configuration Template
# Copy this file to .env and fill in your email credentials

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# Database Configuration
SQLALCHEMY_DATABASE_URI=sqlite:///resqpaws.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Email Configuration (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_SENDER=your_email@gmail.com
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password

# Note: For Gmail:
# 1. Enable "Less secure app access" OR use App Passwords (recommended)
# 2. If 2FA enabled: Generate App Password at https://myaccount.google.com/apppasswords
# 3. Copy the 16-character app password above

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB max file size
UPLOAD_FOLDER=static/uploads

# Optional: Other Email Providers
# Outlook/Hotmail:
# MAIL_SERVER=smtp-mail.outlook.com
# MAIL_PORT=587

# Yahoo Mail:
# MAIL_SERVER=smtp.mail.yahoo.com
# MAIL_PORT=587
