# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ==================== MongoDB Connection ====================
# IMPORTANT: Use MongoDB Atlas (Live) instead of local MongoDB for production/Vercel
# Get your connection string from: https://cloud.mongodb.org/v2/login
# 
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority&tlsInsecure=true
# 
# Steps:
# 1. Create MongoDB Atlas account at cloud.mongodb.org
# 2. Create a cluster
# 3. Go to Database Access → Add database user (save credentials!)
# 4. Go to Network Access → Whitelist IPs (add 0.0.0.0/0 for Vercel)
# 5. Click Connect → Connect your application
# 6. Copy connection string and replace username:password
#
# Example: mongodb+srv://myuser:newpassword123@cluster0.abc123.mongodb.net/sarrs?retryWrites=true&w=majority&tlsInsecure=true
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sarrs?retryWrites=true&w=majority&tlsInsecure=true

# ==================== Email Configuration ====================
# For email notifications (Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password

# Note for Gmail:
# 1. Enable 2-factor authentication
# 2. Generate app-specific password: https://myaccount.google.com/apppasswords
# 3. Use that password here (not your regular Gmail password)

# ==================== Flask Configuration ====================
FLASK_ENV=production
SECRET_KEY=generate_a_secure_random_key_here_min_32_chars

# To generate SECRET_KEY:
# python -c "import secrets; print(secrets.token_hex(32))"

# ==================== Admin Seeding Key ====================
# Used to bootstrap the database on initial deployment
# Allows seeding without needing to login first
# Access: https://your-app.vercel.app/admin/seed-database?key=YOUR_SEED_KEY
ADMIN_SEED_KEY=generate_a_secure_random_key_for_seeding

# ==================== Demo Credentials ====================
# After initial deployment, run: python init_demo_data_live.py
# This creates demo accounts:
#
